# Generated by TortoiseHg setting dialog


[paths]

[ui]
username = Konstantinos Bairaktaris <kbairak@transifex.com>
merge = meld
ssh = ssh -C

[extensions]
zeroconf=
rebase=
transplant=
extdiff = 
graphlog = 
mq = 
children = 
purge = 
parentrevspec = 
graphlog=
color =
crecord = ~/.hgext/crecord
# hggit = ~/devel/env/hg-git/lib/python2.7/site-packages/hggit

[tortoisehg]
editor = gvim
vdiff = meld
ui.language = en
tabwidth = 4

[pager]
pager = less -FRSXQ
quiet = True
